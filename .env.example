# Production Environment Variables for Backend
# Copy this file to .env and update the values for your deployment

# Server Configuration
SERVER_PORT=8080

# CORS Configuration - Comma-separated list of allowed frontend origins
# For local development: http://localhost:*,http://127.0.0.1:*
# For production: https://your-frontend-domain.com,https://www.your-frontend-domain.com
CORS_ALLOWED_ORIGINS=http://localhost:*,http://127.0.0.1:*

# Database Configuration
# For MySQL production deployment
SPRING_DATASOURCE_URL=jdbc:mysql://your-mysql-host:3306/erp_db?useSSL=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=your_db_username
SPRING_DATASOURCE_PASSWORD=your_db_password
SPRING_DATASOURCE_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver

# For H2 (development only)
# SPRING_DATASOURCE_URL=jdbc:h2:mem:erp_db
# SPRING_DATASOURCE_USERNAME=sa
# SPRING_DATASOURCE_PASSWORD=
# SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.h2.Driver

# JPA/Hibernate Configuration
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.MySQLDialect

# JWT Configuration
JWT_SECRET=your-256-bit-secret-key-here-change-in-production
JWT_EXPIRATION_MS=86400000